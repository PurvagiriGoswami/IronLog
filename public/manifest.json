{
  "name": "IronLog",
  "short_name": "IronLog",
  "description": "Minimalist, offline-first workout tracker for serious lifters.",
  "theme_color": "#0a0a0a",
  "background_color": "#0a0a0a",
  "display": "standalone",
  "orientation": "portrait",
  "start_url": "/",
  "icons": [
    {
      "src": "/next.svg",
      "sizes": "192x192",
      "type": "image/svg+xml"
    },
    {
      "src": "/next.svg",
      "sizes": "512x512",
      "type": "image/svg+xml"
    }
  ],
  "shortcuts": [
    {
      "name": "Start Workout",
      "url": "/workout/active",
      "icons": [{ "src": "/next.svg", "sizes": "96x96" }]
    },
    {
      "name": "Log Bodyweight",
      "url": "/progress?action=log",
      "icons": [{ "src": "/next.svg", "sizes": "96x96" }]
    },
    {
      "name": "View PRs",
      "url": "/progress/prs",
      "icons": [{ "src": "/next.svg", "sizes": "96x96" }]
    }
  ]
}
